{
  "runtime_root": "%USERPROFILE%\\file-assistant",
  "obsidian_vault": "%USERPROFILE%\\Documents\\Obsidian",
  "obsidian_run_dir": "%USERPROFILE%\\Documents\\Obsidian\\04 例行工作\\文件管理助手",
  "codex_executable": "%LOCALAPPDATA%\\Programs\\OpenAI\\CodexDesktop\\Codex.exe",
  "allowed_open_roots": [
    "%USERPROFILE%\\file-assistant",
    "%USERPROFILE%\\Documents\\Obsidian"
  ],
  "obsidian_folders": {
    "inbox": "00 收件箱",
    "daily": "01 今日日志",
    "projects": "02 项目",
    "meetings": "03 会议",
    "routine": "04 例行工作",
    "templates": "90 模板",
    "archive": "99 归档",
    "codex_project": "Codex"
  },
  "watch_roots": [
    {
      "name": "Desktop",
      "path": "%USERPROFILE%\\Desktop",
      "max_depth": 2,
      "max_files": 2500
    },
    {
      "name": "Downloads",
      "path": "%USERPROFILE%\\Downloads",
      "max_depth": 2,
      "max_files": 3500
    },
    {
      "name": "Documents",
      "path": "%USERPROFILE%\\Documents",
      "max_depth": 3,
      "max_files": 3000
    },
    {
      "name": "ObsidianInbox",
      "path": "%USERPROFILE%\\Documents\\Obsidian\\00 收件箱",
      "max_depth": 3,
      "max_files": 1000
    },
    {
      "name": "ObsidianProjects",
      "path": "%USERPROFILE%\\Documents\\Obsidian\\02 项目",
      "max_depth": 4,
      "max_files": 3000
    }
  ],
  "exclude_dir_names": [
    ".git",
    ".hg",
    ".svn",
    "__pycache__",
    ".venv",
    "venv",
    "node_modules",
    "AppData",
    "cache",
    "logs",
    "tmp",
    "temp"
  ],
  "recent_days": 7,
  "archive_after_days": 30,
  "installer_after_days": 14,
  "large_file_mb": 200,
  "hash_duplicate_min_mb": 1,
  "hash_duplicate_limit": 80,
  "top_limit": 25,
  "review_keywords": [
    "待办",
    "复盘",
    "报告",
    "总结",
    "简历",
    "面试",
    "合同",
    "发票",
    "SOP",
    "todo",
    "review",
    "report",
    "resume",
    "invoice"
  ]
}
